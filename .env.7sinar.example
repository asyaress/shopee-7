# =============================================================================
# Production - https://7sinar.shop (copy ke .env di server hosting)
# =============================================================================

APP_NAME="Toedjoe Profit Hub"
APP_ENV=production
APP_KEY=                    # php artisan key:generate
APP_DEBUG=false
APP_URL=https://7sinar.shop

# Kredensial untuk reviewer Shopee Open Platform
APP_TEST_USERNAME=administrator
APP_TEST_PASSWORD=123456

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=7sinar.shop

# Shopee Open Platform - Live (production)
SHOPEE_ENV=prod
SHOPEE_PARTNER_ID=2014581
SHOPEE_PARTNER_KEY=
SHOPEE_REDIRECT_URL=https://shopee.toedjoesinargroup.com/integrations/shopee/callback

# Optional - separate Shopee app for Marketing/Ads endpoints
SHOPEE_ADS_PARTNER_ID=
SHOPEE_ADS_PARTNER_KEY=
SHOPEE_ADS_REDIRECT_URL=https://shopee.toedjoesinargroup.com/integrations/shopee/callback

# Optional - separate Shopee app for Affiliate Marketing Solution Management / AMS endpoints
SHOPEE_AMS_PARTNER_ID=
SHOPEE_AMS_PARTNER_KEY=
SHOPEE_AMS_REDIRECT_URL=https://shopee.toedjoesinargroup.com/integrations/shopee/callback

SHOPEE_SHOP_ID=
SHOPEE_SYNC_DAYS=30
SHOPEE_ADS_SYNC_DAYS=30
SHOPEE_CRON_ENABLED=true
SHOPEE_CRON_SYNC_DAYS=1
SHOPEE_CRON_FREQUENCY=hourly

CEO_ALERT_EMAIL=
MOBILE_CEO_ALLOW_ALL_USERS=true
MOBILE_CEO_ALLOWED_EMAILS=
MOBILE_CEO_BOOTSTRAP_EMAIL=admin@gmail.com
MOBILE_CEO_BOOTSTRAP_NAME="Admin Mobile"
MOBILE_CEO_BOOTSTRAP_PASSWORD=password
